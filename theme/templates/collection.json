        "review_AXW9fi": {
          "type": "review",
          "settings": {
            "reviewer": "Monica T.",
            "reviewTitle": "Great quality product, amazing value",
            "reviewDetail": "Nice quality and isn't bulkier than it needs to be. Being able to carry it around with my keys ensure I never forget it in my EDC is so handy, and the protective cap keeps it safe from dust and weather. Great product, would definitely recommend and am even considering getting the longer version for trips!",
            "reviewDate": "inCharge X"
          }
        },
        "review_eJE3Q7": {
          "type": "review",
          "settings": {
            "reviewer": "Russell Hubbard",
            "reviewTitle": "I actually KNOW where my wallet is.",
            "reviewDetail": "It's always nice to find a product which actually performs as advertised. This AirCard, Is That Product! Very happy with the design, build quality and capability of this card. Well done, Rollingsquare! Looking for more great things in the future.",
            "reviewDate": "AirCard"
          }
        },
        "review_Eww3B7": {
          "type": "review",
          "settings": {
            "reviewer": "Georgios Kouvaras",
            "reviewTitle": "TOTALLY SATISFIED CUSTOMER",
            "reviewDetail": "Guys, your rolling square cables ROCK!!! I have all the sizes (keyring, 20cm, 2m and 3m) and they all work perfectly. Even the 3m with a Lumix camera connected to macBook for photo shooting. Flawless, great quality and versatility! (looking forward for TAU 2, the small charger from Kickstarter!)",
            "reviewDate": "inCharge XL"
          }
        },
        "review_YBJwQT": {
          "type": "review",
          "settings": {
            "reviewer": "Bence Dudás",
            "reviewTitle": "Quality product, quality team",
            "reviewDetail": "Even though international shipping lost my parcel, the team did their best to get me my order, and it arrived completely in the end. The products are high quality and they work flawlessly. I can only say they have my full support! 5 stars!",
            "reviewDate": "Service"
          }
        },
        "review_TzixDa": {
          "type": "review",
          "settings": {
            "reviewer": "Guenther Bauer",
            "reviewTitle": "Incredible job guys",
            "reviewDetail": "Incredible job guys! Not only is AirCard a top product, beautiful and yet functional, your customer service is top notch! The original shipment was lost by the logistic company. After writing the problem to the folks at Rolling Square a replacement shipment was on its way in no time. Thanks a lot for such a great service! I'd wish other companies would act like you do!",
            "reviewDate": "AirCard"
          }
        },
        "review_WTAKRG": {
          "type": "review",
          "settings": {
            "reviewer": "Madeleine Carlozzi",
            "reviewTitle": "Game changer...",
            "reviewDetail": "Love my long charger that charges all my different gadgets...it's a game changer. And my magnet I've attached to my iPad Air I use for my iPhone... love having the option to jump from using one screen to the other... another game changer. Such simple, reasonably priced items that are so well designed and thought out ...definitely recommend!!",
            "reviewDate": "inCharge XL"
          }
        },
        "review_bdkwnB": {
          "type": "review",
          "settings": {
            "reviewer": "Hugh P.",
            "reviewTitle": "Great product!",
            "reviewDetail": "Great product. Great service. Saved my wife's life as she never understands all the different cables!",
            "reviewDate": "inCharge X"
          }
        }
      },
