{% assign _ss = section.settings %}
{% assign _section = section.id | split: '__' | last | slice: -4, 4 | prepend: '#banner_' %}
{% assign _press = section.id | split: '__' | last | slice: -4, 4 | prepend: '#press_' %}

{%- capture section_content -%}
  <style>
    .md-s {
      display: none;
    }

    {{ _section }} {
      position: relative;
    }

    {{ _section }} .banner_background {
      position: relative;
      background: transparent no-repeat padding-box;
      background-size: cover;
      background-position: center;
      {% if collection.metafields.custom.mobile_cover_image_on_collection_page %}
        background-image: linear-gradient(15deg, #000000 0%, #9A9A9800 100%), url({{ collection.metafields.custom.mobile_cover_image_on_collection_page | img_url: 'master' }});
      {% else %}
        background-image: linear-gradient(15deg, #000000 0%, #9A9A9800 100%), url({{ collection.featured_image | img_url: '1500x' }});
      {% endif %}
    }

    {{ _section }} .banner_holder {
      position: relative;
      width: 100%;
      min-height: 316px;
      padding: 70px 15px 25px;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: flex-start;
    }

    {{ _section }} .banner_content {
      position: relative;
      width: 100%;
      max-width: 545px;
    }

    {{ _section }} h1.banner_title,
    {{ _section }} .banner_title {
      text-align: left;
      font: normal normal bold 21px/25px Montserrat;
      letter-spacing: 0px;
      color: #FFFFFF;
      padding-bottom: 8px;
      margin: 0;
    }

    {{ _section }} .banner_subtitle {
      text-align: left;
      font: normal normal 500 13px/18px Montserrat;
      letter-spacing: 0px;
      color: #FFFFFF;
    }
    {{ _section }} .banner_subtitle p {
      margin: 0 0 6px 0;
    }
    {{ _section }} .banner_subtitle p:last-child { margin-bottom: 0; }
    {{ _section }} .banner_subtitle a {
      color: #FFFFFF;
      text-decoration: underline;
      text-underline-offset: 2px;
      font-weight: 600;
    }
    {{ _section }} .banner_subtitle a:hover {
      color: #17e260;
    }

    @media screen and (min-width: 450px) {
      {{ _section }} .banner_holder {
        justify-content: center;
      }
    }

    @media screen and (min-width: 768px) {
      .md-s {
        display: block;
      }
      .md-h {
        display: none;
      }

      {{ _section }} .banner_holder {
        min-height: 400px;
        padding: 90px min(8.3vw, 160px) 50px;
      }

      {{ _section }} .banner_content {
        max-width: min(720px, 50%);
      }

      {{ _section }} .banner_title {
        font: normal normal bold 32px/39px Montserrat;
        padding-bottom: 12px;
      }

      {{ _section }} .banner_subtitle {
        font: normal normal 500 17px/26px Montserrat;
      }

      {{ _section }} .banner_background {
        background-image: linear-gradient(15deg, #000000 0%, #9A9A9800 100%), url({{ collection.featured_image | img_url: '1500x' }});
      }
    }

    @media screen and (min-width: 1920px) {
      {{ _section }} .banner_holder {
        max-width: 1920px;
        margin: auto;
      }
    }

    /* ===== Collection press bar (white logos, no scroll-color change) ===== */
    {{ _press }} {
      position: relative;
      pointer-events: none;
    }

    {{ _press }} .press_holder {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      width: 100%;
      max-width: 1920px;
      padding: 14px 16px;
      box-sizing: border-box;
      z-index: 3;
    }

    /* mobile: top of banner */
    @media (max-width: 767px) {
      {{ _press }} .press_holder {
        top: 0;
      }
    }

    /* desktop: bottom of banner */
    @media (min-width: 768px) {
      {{ _press }} .press_holder {
        top: 0;
      }
    }

    {{ _press }} .press-scroller {
      width: 100%;
      overflow: hidden;
      position: relative;
      --gap: 40px;
      --logo-h: 40px;
      --mask-edge: 8%;
      -webkit-mask: linear-gradient(90deg, transparent, #000 var(--mask-edge), #000 calc(100% - var(--mask-edge)), transparent);
              mask: linear-gradient(90deg, transparent, #000 var(--mask-edge), #000 calc(100% - var(--mask-edge)), transparent);
      touch-action: pan-y;
      pointer-events: auto;
    }

    {{ _press }} .press-track {
      display: flex;
      align-items: center;
      gap: var(--gap);
      will-change: transform;
      width: max-content;
      padding: 6px 0;
      transform: translate3d(0,0,0);
      cursor: grab;
      user-select: none;
      -webkit-user-select: none;
    }

    {{ _press }} .press-scroller.is-dragging .press-track {
      cursor: grabbing;
    }

    {{ _press }} .press-item {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: var(--logo-h);
      flex: 0 0 auto;
      opacity: .95;
      transition: opacity .2s, transform .2s;
    }

    {{ _press }} .press-item:hover {
      opacity: 1;
      transform: translateY(-1px);
    }

    {{ _press }} .press-item img {
      height: 100%;
      width: auto;
      display: block;
      filter: grayscale(100%) invert(1) brightness(1.9); /* always white */
      -webkit-user-drag: none;
      user-drag: none;
    }
  </style>

