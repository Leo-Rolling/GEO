{% schema %}
  {
    "name": "Main Collection",
    "settings": [
        {
          "type": "header",
          "content": "Filter settings"
        },
        {
            "type": "collection_list",
            "id": "topFilters",
            "label": "Collections on top half"
        },
        {
            "type": "collection_list",
            "id": "otherFilters",
            "label": "Collections on bottom half"
        },
        {
            "type": "url",
            "id": "filterLink",
            "label": "Shop All Products Button link"
        },
        {
            "type": "header",
            "content": "Section separation settings"
        },
        {
            "type": "checkbox",
            "id": "show_decoration_desktop",
            "label": "Show separation on desktop",
            "default": true
        },
        {
            "type": "image_picker",
            "id": "desktop_decor_icon",
            "label": "Select scrolling icon for desktop"
        },
        {
            "type": "checkbox",
            "id": "show_decoration_mobile",
            "label": "Show separation on mobile",
            "default": true
        },
        {
            "type": "image_picker",
            "id": "mobile_decor_icon",
            "label": "Select scrolling icon for mobile"
        }
    ],
    "blocks": [
      {
        "name": "USP block",
        "type": "usp",
        "limit": 4,
        "settings": [
          {
            "type": "image_picker",
            "id": "icon",
            "label": "USP icon"
          },
          {
            "type": "text",
