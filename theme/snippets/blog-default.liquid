<div class="blog-template blog-template-default rs-blog-listing">
  <div class="container">

    <div class="rs-blog-header">
      {% if current_tags %}
      <h1>
        <a href="{{ blog.url }}">{% render 'multilang' with page_title %}</a> &raquo; {{ current_tags.first }}
      </h1>
      {% else %}
      <h1>{% render 'multilang' with page_title %}</h1>
      <p class="rs-blog-tagline">Stories &amp; Insights from Rolling Square</p>
      {% endif %}
    </div>

    <div class="halo-blog-content">
      {% section 'blog-template' %}
    </div>

  </div>
</div>
