<script>
(() => {
  // Skip if variant is already set via URL
  const qs = new URLSearchParams(location.search);
  if (qs.has('variant')) return;

  // Country → desired plug
  const COUNTRY = {{ localization.country.iso_code | json }};
  const desiredByCountry = {
  // --- North America ---
  US: "US", CA: "US", MX: "US",
  // --- Central & South America ---
  AR: "EU", BO: "EU", BR: "EU", CL: "EU", CO: "EU", CR: "US",
  CU: "US", DO: "US", EC: "EU", GT: "US", HN: "US", NI: "US",
  PA: "US", PE: "EU", PR: "US", PY: "EU", SV: "US", UY: "EU", VE: "EU",

  // --- Europe (mostly EU plug) ---
  AL: "EU", AD: "EU", AT: "EU", BA: "EU", BE: "EU", BG: "EU", BY: "EU",
  CH: "EU", CY: "EU", CZ: "EU", DE: "EU", DK: "EU", EE: "EU", ES: "EU",
  FI: "EU", FR: "EU", GR: "EU", HR: "EU", HU: "EU", IS: "EU", IT: "EU",
  LT: "EU", LU: "EU", LV: "EU", MC: "EU", MD: "EU", ME: "EU", MK: "EU",
  MT: "EU", NL: "EU", NO: "EU", PL: "EU", PT: "EU", RO: "EU", RS: "EU",
  SE: "EU", SI: "EU", SK: "EU", SM: "EU", UA: "EU", VA: "EU",

  // --- UK & Commonwealth territories using UK plug ---
  GB: "UK", IE: "UK", HK: "UK", SG: "UK", MY: "UK", CY: "UK",
  AE: "UK", KW: "UK", QA: "UK", BH: "UK", OM: "UK",
  NG: "UK", GH: "UK", KE: "UK", TZ: "UK", UG: "UK", ZM: "UK", ZW: "UK",
  PK: "UK", BD: "UK", LK: "UK", HK: "UK", MO: "UK",

  // --- Asia ---
  CN: "EU", JP: "US", KR: "EU", TW: "EU", TH: "EU", VN: "EU", ID: "EU",
  PH: "US", IN: "UK", NP: "EU", KH: "EU", LA: "EU", BN: "UK", MM: "EU",

  // --- Middle East ---
  IL: "EU", SA: "UK", AE: "UK", OM: "UK", KW: "UK", QA: "UK", BH: "UK",
  JO: "EU", LB: "EU", TR: "EU", IR: "EU",

  // --- Africa ---
  DZ: "EU", EG: "EU", MA: "EU", TN: "EU", ZA: "UK", MZ: "EU", AO: "EU",
  BJ: "EU", BW: "UK", BF: "EU", CM: "EU", CI: "EU", CD: "EU", CG: "EU",
  ET: "EU", GM: "UK", GN: "EU", KE: "UK", LR: "EU", MG: "EU", ML: "EU",
  MU: "UK", MW: "UK", NA: "UK", NG: "UK", RW: "EU", SC: "UK", SD: "EU",
  SN: "EU", TG: "EU", TZ: "UK", UG: "UK", ZM: "UK", ZW: "UK",

  // --- Oceania & Pacific Islands (default to EU since no AU plug) ---
  NZ: "EU", FJ: "EU", PG: "EU", WS: "EU", TO: "EU", SB: "EU", KI: "EU", TV: "EU", NR: "EU", VU: "EU",

};

  const desired = desiredByCountry[COUNTRY];
  if (!desired) return;

  const run = () => {
    const items = document.querySelectorAll('.variants_holder .s_meta_var');
    if (!items.length) return;

    // Find the matching variant element
    const match = Array.from(items).find(el =>
      (el.getAttribute('var_title') || '').trim().toLowerCase() === desired.toLowerCase()
    );
    if (!match) return;

    // Avoid double-click if it’s already selected
    if (match.classList.contains('selected')) return;

    // Simulate a gentle, delayed click
    setTimeout(() => {
      match.dispatchEvent(new MouseEvent('click', { bubbles: true }));
      match.click?.();
    }, 200);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
})();
</script>
