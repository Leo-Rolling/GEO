<script>
(() => {
  // --- helpers to sync sticky UIs ---
  const syncStickyFrom = ({ id, title, imgUrl }) => {
    // 1) Mobile sticky label
    const mobileLabel = document.querySelector('.meta_variant_options_holder .option_value');
    if (mobileLabel && title) mobileLabel.textContent = title;

    // 2) Desktop sticky select + preview
    const stickySel = document.getElementById('sticky_dropdown');
    if (stickySel && id) {
      if ([...stickySel.options].some(o => String(o.value) === String(id))) {
        stickySel.value = String(id);
        stickySel.dispatchEvent(new Event('input',  { bubbles: true }));
        stickySel.dispatchEvent(new Event('change', { bubbles: true }));
      }
      const opt    = [...stickySel.options].find(o => String(o.value) === String(id));
      const swatch = document.querySelector('.sticky_cta_variant_dropdown .variant_option_color_img');
      if (swatch) {
        const styleUrl = opt?.getAttribute('swatch_style'); // "url(//...jpg)"
        const vImgUrl  = opt?.getAttribute('v_img_url') || imgUrl;
        if (styleUrl) swatch.style.background = styleUrl;
        else if (vImgUrl) swatch.style.background = `url(${vImgUrl})`;
        swatch.style.backgroundSize = 'cover';
        swatch.style.backgroundPosition = 'center';
      }
    }
  };

  const syncFromTile = (tileEl) => {
    if (!tileEl) return;
    const id    = tileEl.getAttribute('var_id');
    const title = tileEl.getAttribute('var_title');
    const img   = tileEl.querySelector('img')?.getAttribute('src');
    syncStickyFrom({ id, title, imgUrl: img });
  };

  // 1) Delegate clicks on tiles → sync sticky UIs
  const attachTileClickSync = () => {
    document.addEventListener('click', (e) => {
      const tile = e.target.closest?.('.variants_holder .s_meta_var');
      if (!tile) return;
      // sync after theme handles the click/change
      setTimeout(() => syncFromTile(tile), 0);
    });
  };

  // 2) Observe selection class changes on tiles (covers programmatic changes)
  const observeTileSelection = () => {
    const holder = document.querySelector('.variants_holder');
    if (!holder) return;
    new MutationObserver(() => {
      const sel = holder.querySelector('.s_meta_var.selected');
      if (sel) syncFromTile(sel);
    }).observe(holder, { subtree: true, attributes: true, attributeFilter: ['class'] });
  };

  // 3) Watch the hidden variant id input
  const observeVariantIdInput = () => {
    const idInput = document.querySelector('form[action*="/cart/add"] [name="id"]');
    if (!idInput) return;
    new MutationObserver(() => {
      const val = idInput.value;
      if (!val) return;
      const tile = document.querySelector(`.variants_holder .s_meta_var[var_id="${val}"]`);
      if (tile) syncFromTile(tile);
    }).observe(idInput, { attributes: true, attributeFilter: ['value'] });
  };

  // 4) Listen to common custom events from themes
  const attachVariantChangeSync = () => {
    const handler = (e) => {
      const v = e.detail?.variant || e.detail;
      if (!v) return;
      const tileById = document.querySelector(`.variants_holder .s_meta_var[var_id="${v.id}"]`);
      if (tileById) { syncFromTile(tileById); return; }
      const guess = (v.option1 || v.title || '').trim();
      const tileByTitle = document.querySelector(`.variants_holder .s_meta_var[var_title="${guess}"]`);
      if (tileByTitle) syncFromTile(tileByTitle);
    };
    document.addEventListener('variant:change', handler);
    document.addEventListener('product:variant-change', handler);
  };

  // 5) Keep sticky dropdown changes in sync back to tiles + mobile label
  const attachStickyDropdownSync = () => {
    const stickySel = document.getElementById('sticky_dropdown');
    if (!stickySel) return;
    stickySel.addEventListener('change', () => {
      const id    = stickySel.value;
      const opt   = stickySel.options[stickySel.selectedIndex];
      const title = (opt?.text || '').trim();
      const img   = opt?.getAttribute('v_img_url') || '';
      // Update sticky (self) + mobile label immediately
      syncStickyFrom({ id, title, imgUrl: img });
      // Also reflect selection in tiles
      const tile = document.querySelector(`.variants_holder .s_meta_var[var_id="${id}"]`);
      if (tile && !tile.classList.contains('selected')) {
        // simulate the same click users would do
        tile.dispatchEvent(new MouseEvent('click', { bubbles: true }));
        tile.click?.();
      }
    });
  };

  // Initial sync once (from current selected tile if present)
  const initialSync = () => {
    const sel = document.querySelector('.variants_holder .s_meta_var.selected');
    if (sel) syncFromTile(sel);
  };

  const run = () => {
    // Only activate on pages that have at least one of the UIs
    if (!document.querySelector('.variants_holder') && !document.getElementById('sticky_dropdown')) return;

    initialSync();
    attachTileClickSync();
    observeTileSelection();
    observeVariantIdInput();
    attachVariantChangeSync();
    attachStickyDropdownSync();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
})();
</script>


