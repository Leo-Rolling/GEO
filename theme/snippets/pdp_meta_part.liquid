<script>
    const variant_image_ids = {
        {% for variant in product.variants %}
            {% if variant.image %}
                '{{ variant.id }}': {{ variant.image.id }},
            {% endif %}
        {% endfor %}
    };

    
const variant_price_htmls = {
    {% for variant in product.variants %}
        {% capture price_html %}
            {% if variant.compare_at_price > variant.price %}
                <div class="p_meta_now_price">{{ variant.price | money }}</div>
                <div class="p_meta_was_price">{{ variant.compare_at_price | money }}</div>
                    <div class="p_saving_percent">SAVE {{ variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price }}%</div>

            {% else %}
                <div class="p_meta_price">{{ variant.price | money }}</div>
            {% endif %}
        {% endcapture %}
        '{{ variant.id }}': `{{ price_html | strip }}`,
    {% endfor %}
};

  const variant_price_only_htmls = {
        {% for variant in product.variants %}
            {% capture price_only %}
                {{ variant.price | money }}
            {% endcapture %}
            '{{ variant.id }}': `{{ price_only | strip }}`,
        {% endfor %}
    };

    function update_pdp_slider_img(v_id) {
        var img_id = variant_image_ids[v_id];

        if (img_id != undefined) {
            var swiper_index = parseInt($('[img_id="' + img_id + '"]').parent().attr('index'));
            swiper2.slideTo(swiper_index);
            mobile_m_swiper.slideTo(swiper_index);
        }
    }

    function update_price_html(v_id) {
        var price_html = variant_price_htmls[v_id];
        var price_only = variant_price_only_htmls[v_id];
        $('.p_meta_price_holder').html(price_html);
        $('.sticky_mob_add_to_cart_price').html(price_only);
      
    }

    $('#meta_quantity_decrease').on('click', function() {
        var currentValue = parseInt($('#meta_quantity-input').val());
        if (currentValue > 1) {
            $('#meta_quantity-input').val(currentValue - 1);
            update_promo_banner(currentValue - 1);
        }
    });

    // Increase quantity
    $('#meta_quantity_increase').on('click', function() {
        var currentValue = parseInt($('#meta_quantity-input').val());
        $('#meta_quantity-input').val(currentValue + 1);
        update_promo_banner(currentValue + 1);
    });

    $('input#meta_quantity-input').change(function () {
        var quantity = parseInt($(this).val());
        if (quantity < 1) {
            quantity = 1;
        }

        $(this).val(quantity);
        update_promo_banner(quantity);
    });

    function update_promo_banner(quantity) {
        $('.pdp_save_more').hide();
        var quantities_array = [];
        $('.pdp_save_more').each(function () {
            var s_quan = parseInt($(this).attr('quantity'));
            quantities_array.push(s_quan);
        });

        var quantity_to_show = findNumber(quantities_array, quantity);
        $(`.pdp_save_more[quantity="${quantity_to_show}"]`).show();
    }

    function findNumber(arr, x) {
        let greaterNums = arr.filter(num => num > x);
        if (greaterNums.length > 0) {
            return Math.min(...greaterNums);
        } else {
            return Math.max(...arr);
        }
    }

    const updateProductPage = () => {
        fetch('{{ request.path }}?section_id={{ section.id }}')
        .then(res => res.text())
        .then(res => {
            $('.pdp_save_message').replaceWith($(res).find('.pdp_save_message'));
        })
    };
</script>

